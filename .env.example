# Turso cloud database (required for production)
# Sign up free at https://turso.tech, then run:
#   turso db create linkit
#   turso db show linkit --url
#   turso db tokens create linkit
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token-here

# Password to log into /dashboard
DASHBOARD_PASSWORD=your-secure-password

# Any random 32+ character string (used to sign session cookies)
SESSION_SECRET=change-this-to-a-long-random-string
